{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Launch PythiaJS (App + Server)",
      "runtimeExecutable": "bun",
      "runtimeArgs": ["run", "src/main-new.js"],
      "cwd": "${workspaceFolder}",
      "console": "internalConsole",
      "outputCapture": "std"
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Server Only",
      "runtimeExecutable": "bun",
      "runtimeArgs": ["run", "src/server.js"],
      "cwd": "${workspaceFolder}",
      "console": "internalConsole",
      "outputCapture": "std",
      "killBehavior": "polite"
    }
  ],
  "compounds": []
}
